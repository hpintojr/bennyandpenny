# Contact form — copy to .env.local (local) and add to Vercel Project → Settings → Environment Variables.
# The form works if EITHER channel is configured; set both for DB + email.

# --- Neon (Postgres) ---
# Connection string from the Neon dashboard (use the pooled connection string).
DATABASE_URL=

# --- Mailjet (transactional email) ---
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
# From must be a verified Mailjet sender/domain. Defaults to hello@bennyandpenny.com.
MAILJET_FROM_EMAIL=hello@bennyandpenny.com
MAILJET_FROM_NAME=Benny & Penny's Website

# Where inquiries are delivered. Defaults to hello@bennyandpenny.com.
CONTACT_TO_EMAIL=hello@bennyandpenny.com
